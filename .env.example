# ─── Database ─────────────────────────────────────────────────────────────
# Single Postgres (pgvector) for relational + embeddings + pg-boss queue.
DATABASE_URL="postgresql://recall:recall@localhost:5433/recall?schema=public"

# ─── App ──────────────────────────────────────────────────────────────────
APP_PORT=3000
APP_ENV=development
LOG_LEVEL=info

# Local audio storage root (owned storage — never a third-party bucket at MVP).
STORAGE_ROOT=./storage

# ─── Transcription engine (swappable adapter) ──────────────────────────────
# One of: mock | sarvam | openai
# Nothing downstream of the adapter references a specific vendor (PRD F3/§8).
TRANSCRIPTION_ENGINE=mock
SARVAM_API_KEY=
SARVAM_BASE_URL=https://api.sarvam.ai
OPENAI_API_KEY=
# Audio chunking threshold in seconds for engines with per-request limits.
TRANSCRIBE_CHUNK_SECONDS=1800
# Engine timeout budget: 10 min per hour of audio (PRD F3 [CONFIG]).
TRANSCRIBE_TIMEOUT_MS_PER_HOUR=600000

# ─── Intelligence (Claude) ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Model id for structuring/normalization. Default = most capable Opus tier.
# A cheaper tier (claude-sonnet-4-6 / claude-haiku-4-5) trades quality for the
# PRD's <=Rs15/audio-hour cost target — benchmark before switching.
CLAUDE_MODEL=claude-opus-4-8
# Effort for structuring (low|medium|high|max). Low keeps token spend down on
# what is mostly an extraction task; raise if tagging quality suffers.
CLAUDE_EFFORT=low

# ─── Embeddings ────────────────────────────────────────────────────────────
# Embedding provider: openai | mock. Dimension MUST match the pgvector column.
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ─── Limits / config (PRD) ─────────────────────────────────────────────────
UPLOAD_MAX_BYTES=1073741824          # 1 GB (F2)
MIN_AUDIO_SECONDS=30                  # calls < 30s are skipped (F1/F3)
CONTEXT_PACK_TOKEN_BUDGET=6000        # F8
WORKER_HEARTBEAT_STALE_MS=300000     # /health flags worker stale > 5 min (REQ-16.1)

# ─── Auth (MVP dev shim) ───────────────────────────────────────────────────
# Real deployment reuses onboarding's session auth. For local dev the API
# trusts an x-user-id header resolved against the seeded users table.
DEV_AUTH_TRUST_HEADER=true
